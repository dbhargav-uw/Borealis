# Borealis environment — copy to .env and fill in. NEVER commit a real .env.

# Anthropic key for the "why this site" briefing + NL search (P4).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Frontend dev origin the backend allows through CORS.
FRONTEND_ORIGIN=http://localhost:5173

# Resource provider (site selection): NASA POWER regional climatology (no key needed).
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/climatology/regional

# DEFERRED operational act: Open-Meteo ensemble endpoint (/api/operational/assess).
OPEN_METEO_BASE_URL=https://ensemble-api.open-meteo.com/v1/ensemble
