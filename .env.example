# Borealis environment — copy to .env and fill in. NEVER commit a real .env.

# API key for the "why this site" briefing + NL search (P4). Read from GEMINI_API_KEY,
# but still used with the Anthropic API — get one at https://console.anthropic.com/
GEMINI_API_KEY=

# Frontend dev origin the backend allows through CORS.
FRONTEND_ORIGIN=http://localhost:5173

# Cesium ion token for the high-fidelity earth (Bing World Imagery + World Terrain).
# Free tier is fine — create one at https://ion.cesium.com/tokens. Leave blank to fall
# back to Cesium's bundled offline Natural Earth II imagery. This is a FRONTEND var:
# put it in frontend/.env (Vite only exposes VITE_-prefixed vars to the browser).
VITE_CESIUM_ION_TOKEN=

# Resource provider (site selection): NASA POWER regional climatology (no key needed).
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/climatology/regional

# DEFERRED operational act: Open-Meteo ensemble endpoint (/api/operational/assess).
OPEN_METEO_BASE_URL=https://ensemble-api.open-meteo.com/v1/ensemble
