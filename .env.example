# Borealis environment — copy to .env and fill in. NEVER commit a real .env.

# Anthropic key for the AI briefing layer (Phase 3).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Frontend dev origin the backend allows through CORS.
FRONTEND_ORIGIN=http://localhost:5173

# Forecast provider (Phase 2): Open-Meteo ensemble endpoint.
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/ensemble
